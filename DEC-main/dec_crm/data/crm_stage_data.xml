<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================== -->
        <!-- DEC CRM PIPELINE STAGES (8 Custom Stages)                        -->
        <!-- Flow: Enquiry → QRF → Design Review → Tech Meeting               -->
        <!--       → Quotation → Negotiations → Won/Lost                     -->
        <!-- ============================================================== -->

        <!-- Stage 1: Enquiry (initial stage) -->
        <record id="dec_stage_enquiry" model="crm.stage">
            <field name="name">Enquiry</field>
            <field name="sequence">1</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">3</field>
        </record>

        <!-- Stage 2: QRF (Quotation Requirement Form) -->
        <record id="dec_stage_qrf" model="crm.stage">
            <field name="name">QRF</field>
            <field name="sequence">2</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">3</field>
        </record>

        <!-- Stage 3: Design Review -->
        <record id="dec_stage_design_review" model="crm.stage">
            <field name="name">Design Review</field>
            <field name="sequence">3</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">5</field>
        </record>

        <!-- Stage 4: Technical Meeting -->
        <record id="dec_stage_technical_meeting" model="crm.stage">
            <field name="name">Technical Meeting</field>
            <field name="sequence">4</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">5</field>
        </record>

        <!-- Stage 5: Quotation -->
        <record id="dec_stage_quotation" model="crm.stage">
            <field name="name">Quotation</field>
            <field name="sequence">5</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">7</field>
        </record>

        <!-- Stage 6: Negotiations -->
        <record id="dec_stage_negotiations" model="crm.stage">
            <field name="name">Negotiations</field>
            <field name="sequence">6</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">10</field>
        </record>

        <!-- Stage 7: Won (is_won = True) -->
        <record id="dec_stage_won" model="crm.stage">
            <field name="name">Won</field>
            <field name="sequence">7</field>
            <field name="is_won">True</field>
            <field name="rotting_threshold_days">0</field>
        </record>

        <!-- Stage 8: Lost -->
        <record id="dec_stage_lost" model="crm.stage">
            <field name="name">Lost</field>
            <field name="sequence">8</field>
            <field name="is_won">False</field>
            <field name="rotting_threshold_days">0</field>
        </record>

    </data>
</odoo>
