<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================== -->
        <!-- SEQUENCES                                                       -->
        <!-- ============================================================== -->
        <record id="seq_dec_qrf" model="ir.sequence">
            <field name="name">DEC QRF Sequence</field>
            <field name="code">dec.qrf</field>
            <field name="prefix">QRF/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_dec_cross_sell" model="ir.sequence">
            <field name="name">DEC Cross-Sell Sequence</field>
            <field name="code">dec.cross.sell</field>
            <field name="prefix">CS-%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_dec_quotation" model="ir.sequence">
            <field name="name">DEC Quotation Sequence</field>
            <field name="code">dec.quotation</field>
            <field name="prefix">QT-%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_quotation_revision_request" model="ir.sequence">
            <field name="name">Quotation Revision Request Sequence</field>
            <field name="code">quotation.revision.request</field>
            <field name="prefix">REV-%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ============================================================== -->
        <!-- DEC PRODUCT VERTICALS                                           -->
        <!-- NOTE: Verticals are now created dynamically by the user.      -->
        <!-- Create them via: DEC Settings → Product Verticals              -->
        <!-- ============================================================== -->

        <!-- ============================================================== -->
        <!-- UTM SOURCES — DEC Lead Sources                                  -->
        <!-- ============================================================== -->
        <record id="utm_source_direct_visit" model="utm.source">
            <field name="name">Direct Sales Visit</field>
        </record>

        <record id="utm_source_online" model="utm.source">
            <field name="name">Online Enquiry / Portal</field>
        </record>

        <record id="utm_source_customer_ref" model="utm.source">
            <field name="name">Customer Reference</field>
        </record>

        <record id="utm_source_architect" model="utm.source">
            <field name="name">Architect / Consultant</field>
        </record>

        <record id="utm_source_contractor" model="utm.source">
            <field name="name">Contractor / Supplier Referral</field>
        </record>

        <record id="utm_source_tenders" model="utm.source">
            <field name="name">Tenders</field>
        </record>

    </data>
</odoo>
