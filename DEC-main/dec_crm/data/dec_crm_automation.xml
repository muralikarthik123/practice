<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================== -->
        <!-- HIGH-VALUE LEAD AUTO-ESCALATION                                 -->
        <!-- ============================================================== -->

        <!-- Server Action: Set priority for high-value leads -->
        <record id="action_high_value_escalation" model="ir.actions.server">
            <field name="name">DEC: High-Value Lead Escalation</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">
for lead in records:
    if lead.expected_revenue and lead.expected_revenue >= 5000000:
        lead.write({'priority': '3'})
            </field>
        </record>

        <!-- Automation Rule: Trigger on expected_revenue write -->
        <record id="rule_high_value_escalation" model="base.automation">
            <field name="name">DEC: Escalate High-Value Leads (>₹50L)</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="trigger">on_write</field>
            <field name="trigger_field_ids" eval="[(6, 0, [ref('crm.field_crm_lead__expected_revenue')])]"/>
            <field name="filter_domain">[('expected_revenue', '>=', 5000000)]</field>
            <field name="action_server_ids" eval="[(4, ref('dec_crm.action_high_value_escalation'))]"/>
        </record>

        <!-- ============================================================== -->
        <!-- QRF STATE SYNC FROM APPROVAL REQUEST                            -->
        <!-- ============================================================== -->

        <!-- Server Action: Sync QRF state from approval request status -->
        <record id="action_sync_qrf_state_from_approval" model="ir.actions.server">
            <field name="name">DEC: Sync QRF State from Approval</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="state">code</field>
            <field name="code">
for req in records:
    if req.qrf_id and req.request_status:
        req.qrf_id.write({'state': req.request_status})
            </field>
        </record>

    </data>
</odoo>
