<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================== -->
        <!-- STAGE-WISE ESCALATION CRON                                       -->
        <!-- Runs every 1 minute. Calls crm.lead._cron_check_stage_         -->
        <!-- escalations() which drives the L1 (Business Head) → L2          -->
        <!-- (Marketing Head) chain for any lead stalled more than          -->
        <!-- 5 minutes in its current stage.                                 -->
        <!-- ============================================================== -->

        <record id="ir_cron_stage_escalation_monitor" model="ir.cron">
            <field name="name">DEC: Stage Escalation Monitor</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_stage_escalations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="priority">5</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>