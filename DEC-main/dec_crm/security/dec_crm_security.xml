<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================== -->
        <!-- SECURITY GROUPS — DEC ROLES                                     -->
        <!-- Note: category_id removed in Odoo 19                            -->

        <!-- Hierarchy: Sales Exec → CRM Team → Vertical Head           -->
        <!-- ============================================================== -->

        <!-- Level 1: Sales Executive (base level) -->
        <record id="group_sales_executive" model="res.groups">
            <field name="name">Sales Executive</field>
            <field name="comment">Field sales executives. Can manage own leads, create QRFs.</field>
        </record>

        <!-- Level 2: CRM Team (implies Sales Executive) -->
        <record id="group_crm_team" model="res.groups">
            <field name="name">CRM Team</field>
            <field name="implied_ids" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="comment">Office-based CRM team. Can verify leads, see team data, approve.</field>
        </record>

        <!-- Costing Team (independent role) -->
        <record id="group_costing_team" model="res.groups">
            <field name="name">Costing Team</field>
            <field name="comment">Costing team. Generates quotations.</field>
        </record>

        <!-- Design Reviewer (independent role) -->
        <record id="group_design_reviewer" model="res.groups">
            <field name="name">Design Reviewer</field>
            <field name="comment">Design team. Reviews QRFs for technical feasibility.</field>
        </record>

        <!-- Level 3: Vertical Head (implies CRM Team) -->
        <record id="group_vertical_head" model="res.groups">
            <field name="name">Vertical Head</field>
            <field name="implied_ids" eval="[(4, ref('group_crm_team'))]"/>
            <field name="comment">Head of a product vertical (Windows/Doors/Panels/PEB). L1 Approver.</field>
        </record>

        <!-- Business Head (top management) -->
        <record id="group_business_head" model="res.groups">
            <field name="name">Business Head</field>
            <field name="comment">Business Head. L2 Approver for quotations.</field>
        </record>

        <!-- CGO (top management, was Marketing Head) -->
        <record id="group_marketing_head" model="res.groups">
            <field name="name">CGO</field>
            <field name="comment">CGO (was Marketing Head). L2 Approver. Cross-sell lead creation.</field>
        </record>

        <!-- CEO (top management) — full access + L3 escalation recipient.
             implied_ids sets up the inheritance: any user in CEO group
             automatically has Odoo's full-admin rights (base.group_system).
             That gives CEO unrestricted record-rule visibility across
             every DEC CRM model without having to duplicate rules. -->
        <record id="group_ceo" model="res.groups">
            <field name="name">CEO</field>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
            <field name="comment">CEO. Top management. Has full system access
                (inherits base.group_system) and acts as the L3 escalation
                recipient after both BH and MH have failed to act within
                5 minutes each.</field>
        </record>

        <!-- Finance User -->
        <record id="group_finance" model="res.groups">
            <field name="name">Finance User</field>
            <field name="comment">Finance team. Collections, credit data, payment tracking.</field>
        </record>

    </data>

    <!-- ================================================================== -->
    <!-- RECORD RULES — DATA ISOLATION                                       -->
    <!-- ================================================================== -->
    <data noupdate="1">

        <!-- Sales Executive: See own leads AND sub-leads they created -->
        <record id="rule_lead_sales_exec_own" model="ir.rule">
            <field name="name">DEC: Sales Exec sees own leads and sub-leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[
                '|',
                ('user_id', '=', user.id),
                ('parent_lead_id.user_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Override Odoo base rule: Personal Leads for sales_team.group_sale_salesman -->
        <!-- This ensures Sales Execs ONLY see their own leads, not all leads -->
        <record id="crm_rule_personal_lead" model="ir.rule">
            <field name="name">Personal Leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Override Odoo base rule: All Leads for sales_team.group_sale_salesman_all_leads -->
        <!-- This ensures Sales Execs with all_leads group still only see their own leads -->
        <record id="crm_rule_all_lead" model="ir.rule">
            <field name="name">All Leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- CRM Team: See own leads, claimed leads, unclaimed leads (not claimed by others), AND sub-leads -->
        <record id="rule_lead_crm_team" model="ir.rule">
            <field name="name">DEC: CRM Team sees own leads, claimed leads, and sub-leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[
                '|', '|', '|',
                # Lead assigned to this user
                ('user_id', '=', user.id),
                # Lead claimed by this user
                ('claimed_by', '=', user.id),
                # Unclaimed leads (available for pickup - but NOT claimed by anyone else)
                '&amp;', ('is_in_capturing_details', '=', False),
                    ('assignment_state', '=', 'unclaimed'),
                    ('claimed_by', '=', False),
                # Sub-leads of own leads
                '&amp;', ('parent_lead_id', '!=', False),
                    ('parent_lead_id.user_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Vertical Head: See only leads assigned to them (vh_user_id = current user) -->
        <record id="rule_lead_vertical_head_all" model="ir.rule">
            <field name="name">DEC: Vertical Head sees assigned leads only</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('vh_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vertical_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Business Head: Full access -->
        <record id="rule_lead_business_head_all" model="ir.rule">
            <field name="name">DEC: Business Head sees all leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_business_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- CGO (was Marketing Head): Full access -->
        <record id="rule_lead_marketing_head_all" model="ir.rule">
            <field name="name">DEC: CGO sees all leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_marketing_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Costing Team: See leads assigned to them OR unclaimed leads in Quotation stage+ -->
        <!-- After claim, costing_user_id is set so they see via first condition -->
        <!-- Before claim, they need to see Quotation-stage leads to be able to claim them -->
        <record id="rule_lead_costing_team_read" model="ir.rule">
            <field name="name">DEC: Costing Team sees assigned leads and unclaimed Quotation-stage leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[
                '|',
                ('costing_user_id', '=', user.id),
                '&amp;', ('costing_user_id', '=', False), ('stage_id.sequence', '&gt;=', 5)
            ]</field>
            <field name="groups" eval="[(4, ref('group_costing_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Design Reviewer: See all leads where design_user_id = current user (any stage) -->
        <record id="rule_lead_design_reviewer_read" model="ir.rule">
            <field name="name">DEC: Design Reviewer sees assigned leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('design_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_design_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Multi-Company Isolation (global rule) -->
        <record id="rule_lead_multi_company" model="ir.rule">
            <field name="name">DEC: Multi-Company Lead Isolation</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Product Vertical: Everyone can read -->
        <record id="rule_product_vertical_read_all" model="ir.rule">
            <field name="name">DEC: Product Vertical - Read All</field>
            <field name="model_id" ref="dec_crm.model_dec_product_vertical"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — Contact Persons and Branches                      -->
        <!-- ============================================================== -->

        <!-- Sales Executive: Own lead's contact persons only -->
        <record id="rule_contact_person_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead contact persons</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_contact_person"/>
            <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- CRM Team and above: Full access to all contact persons -->
        <record id="rule_contact_person_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all contact persons</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_contact_person"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Design Reviewer: Read access to all contact persons (needs to see lead details) -->
        <record id="rule_contact_person_design_reviewer" model="ir.rule">
            <field name="name">DEC: Design Reviewer reads all contact persons</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_contact_person"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_design_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Sales Executive: Own lead's branches only -->
        <record id="rule_branch_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead branches</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_branch"/>
            <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- CRM Team and above: Full access to all branches -->
        <record id="rule_branch_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all branches</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_branch"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Design Reviewer: Read access to all branches (needs to see lead details) -->
        <record id="rule_branch_design_reviewer" model="ir.rule">
            <field name="name">DEC: Design Reviewer reads all branches</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_branch"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_design_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — Cross-Sell Visibility                           -->
        <!-- ============================================================== -->

        <!-- Sales Exec: Only see cross-sells ASSIGNED TO THEM -->
        <record id="rule_cross_sell_own" model="ir.rule">
            <field name="name">DEC: Sales Exec sees assigned cross-sells only</field>
            <field name="model_id" ref="dec_crm.model_dec_cross_sell"/>
            <field name="domain_force">[('assigned_to', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- CRM Team: See ALL cross-sells -->
        <record id="rule_cross_sell_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team sees all cross-sells</field>
            <field name="model_id" ref="dec_crm.model_dec_cross_sell"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Vertical Head: See ALL cross-sells (via implied_ids from CRM Team) -->
        <!-- Business Head: See ALL cross-sells -->
        <record id="rule_cross_sell_business_head_all" model="ir.rule">
            <field name="name">DEC: Business Head sees all cross-sells</field>
            <field name="model_id" ref="dec_crm.model_dec_cross_sell"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_business_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- CGO (was Marketing Head): See ALL cross-sells -->
        <record id="rule_cross_sell_marketing_head_all" model="ir.rule">
            <field name="name">DEC: CGO sees all cross-sells</field>
            <field name="model_id" ref="dec_crm.model_dec_cross_sell"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_marketing_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — QRF (Lead Access)                                -->
        <!-- ============================================================== -->

        <!-- Sales Exec: Own lead's QRFs -->
        <record id="rule_qrf_sales_exec_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead QRFs</field>
            <field name="model_id" ref="dec_crm.model_dec_qrf"/>
            <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- CRM Team and above: Full access to all QRFs -->
        <record id="rule_qrf_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all QRFs</field>
            <field name="model_id" ref="dec_crm.model_dec_qrf"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — QRF Line                                         -->
        <!-- ============================================================== -->

        <record id="rule_qrf_line_sales_exec_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead QRF lines</field>
            <field name="model_id" ref="dec_crm.model_dec_qrf_line"/>
            <field name="domain_force">[('qrf_id.lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_qrf_line_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all QRF lines</field>
            <field name="model_id" ref="dec_crm.model_dec_qrf_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — Vertical Quantity                               -->
        <!-- ============================================================== -->

        <record id="rule_vertical_qty_sales_exec_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead vertical qty</field>
            <field name="model_id" ref="dec_crm.model_dec_lead_vertical_qty"/>
            <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_vertical_qty_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all vertical qty</field>
            <field name="model_id" ref="dec_crm.model_dec_lead_vertical_qty"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — Enquiry Document                                -->
        <!-- ============================================================== -->

        <record id="rule_enquiry_doc_sales_exec_own" model="ir.rule">
            <field name="name">DEC: Sales Exec manages own lead enquiry docs</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_enquiry_document"/>
            <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_executive'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_enquiry_doc_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all enquiry docs</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_enquiry_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — Design Document                                -->
        <!-- ============================================================== -->

        <record id="rule_design_doc_design_reviewer" model="ir.rule">
            <field name="name">DEC: Design Reviewer manages design documents</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_design_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_design_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_design_doc_crm_all" model="ir.rule">
            <field name="name">DEC: CRM Team+ manages all design documents</field>
            <field name="model_id" ref="dec_crm.model_crm_lead_design_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================== -->
        <!-- RECORD RULES — DEC Escalation                                  -->
        <!-- Visibility: SE/CR see own-lead escalations (follower or         -->
        <!-- assignee); BH and MH see all escalations; CRM Team inherits    -->
        <!-- BH's permission via rule_kcrm_team.                             -->
        <!-- ============================================================== -->

        <record id="rule_escalation_crm_team" model="ir.rule">
            <field name="name">DEC: CRM Team+ sees all escalations</field>
            <field name="model_id" ref="dec_crm.model_dec_escalation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_crm_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_escalation_business_head" model="ir.rule">
            <field name="name">DEC: Business Head sees all escalations</field>
