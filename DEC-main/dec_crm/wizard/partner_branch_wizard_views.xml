<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- PARTNER BRANCH WIZARD FORM                                          -->
    <!-- ================================================================== -->
    <record id="view_dec_partner_branch_wizard_form" model="ir.ui.view">
        <field name="name">dec.partner.branch.wizard.form</field>
        <field name="model">dec.partner.branch.wizard</field>
        <field name="arch" type="xml">
            <form string="Create New Branch">
                <group string="Company">
                    <field name="company_id" readonly="1" class="fw-bold"/>
                </group>

                <group string="Branch Details">
                    <group string="Contact Details">
                        <field name="name" placeholder="e.g., Mumbai Office, Bangalore Site"
                               required="1"/>
                        <field name="contact_name" placeholder="Primary contact person"/>
                        <field name="phone" placeholder="Phone number"/>
                        <field name="email" placeholder="Email address"/>
                    </group>
                    <group string="Branch Address">
                        <separator/>
                        <field name="street" placeholder="Street address"/>
                        <field name="street2" placeholder="Street address line 2"/>
                        <field name="city" placeholder="City"/>
                        <field name="state_id"
                               options="{'no_open': True}"
                               placeholder="Select state"/>
                        <field name="zip" placeholder="ZIP code"/>
                        <field name="country_id"
                               options="{'no_open': True}"
                               placeholder="Select country"/>
                    </group>
                </group>

                <footer>
                    <button name="action_create_branch" string="Create Branch"
                            type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- PARTNER BRANCH WIZARD ACTION                                       -->
    <!-- ================================================================== -->
    <record id="action_dec_partner_branch_wizard" model="ir.actions.act_window">
        <field name="name">Create New Branch</field>
        <field name="res_model">dec.partner.branch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_dec_partner_branch_wizard_form"/>
    </record>

</odoo>
