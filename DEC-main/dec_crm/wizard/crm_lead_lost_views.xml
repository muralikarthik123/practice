<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- LOST LEAD WIZARD — Form View                                        -->
    <!-- ================================================================== -->
    <record id="dec_crm_lead_lost_view_form" model="ir.ui.view">
        <field name="name">dec.crm.lead.lost.form</field>
        <field name="model">dec.crm.lead.lost</field>
        <field name="arch" type="xml">
            <form string="Mark Lead as Lost">
                <group string="Loss Details">
                    <field name="lead_id" invisible="1"/>
                    <field name="lost_reason_id" placeholder="Select reason for loss..."/>
                    <field name="competitor_name" placeholder="Enter competitor name if known..."/>
                    <field name="competitor_price" placeholder="Enter competitor price if known..."/>
                </group>
                <separator/>
                <notebook>
                    <page name="remarks">
                        <group>
                            <group string="Sales Feedback">
                                <separator/>
                                <field name="sales_remarks" nolabel="1"
                                       placeholder="Why did we lose this deal?"/>
                            </group>
                            <group string="Manager Feedback">
                                <separator/>
                                <field name="manager_remarks" nolabel="1"
                                       placeholder="Manager's perspective..."/>
                            </group>
                        </group>
                        <group>
                            <group string="Technical Feedback">
                                <separator/>
                                <field name="technical_remarks" nolabel="1"
                                       placeholder="Any technical gaps or issues?"/>
                            </group>
                        </group>
                    </page>
                    <page name="followup">
                        <group string="Follow-up Details">
                            <group>
                                <field name="follow_up_date" placeholder="Select follow-up date..."/>
                            </group>
                        </group>
                        <group>
                            <field name="follow_up_action" nolabel="1" colspan="2"
                                   placeholder="What should we do to re-engage this customer?"/>
                        </group>
                    </page>
                </notebook>
                <footer>
                    <button name="action_mark_lost" type="object"
                            string="Mark as Lost" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_dec_crm_lead_lost" model="ir.actions.act_window">
        <field name="name">Mark Lead as Lost</field>
        <field name="res_model">dec.crm.lead.lost</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_lead_id': active_id}</field>
    </record>

</odoo>
