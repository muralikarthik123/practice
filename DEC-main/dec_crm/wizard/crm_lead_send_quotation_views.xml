<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Send Quotation to Client Wizard -->
    <record id="crm_lead_send_quotation_wizard_view_form" model="ir.ui.view">
        <field name="name">crm.lead.send.quotation.wizard.form</field>
        <field name="model">crm.lead.send.quotation.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Quotation to Client">
                <group>
                    <group string="Recipient">
                        <field name="partner_id" readonly="1"/>
                        <field name="email_to" readonly="1"/>
                    </group>
                    <group string="Email Details">
                        <field name="quotation_id" readonly="1"/>
                        <field name="subject"/>
                    </group>
                </group>
                <group string="Email Body">
                    <field name="body" nolabel="1"/>
                </group>
                <group string="Attachment">
                    <field name="attachment_id" readonly="1" filename="attachment_name"/>
                </group>
                <footer>
                    <button name="action_send_email" string="Send Email" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_crm_lead_send_quotation_wizard" model="ir.actions.act_window">
        <field name="name">Send Quotation to Client</field>
        <field name="res_model">crm.lead.send.quotation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
