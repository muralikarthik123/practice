<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- DEC QUOTATION — Form View                                           -->
    <!-- ================================================================== -->
    <record id="dec_quotation_view_form" model="ir.ui.view">
        <field name="name">dec.quotation.form</field>
        <field name="model">dec.quotation</field>
        <field name="arch" type="xml">
            <form string="Quotation">
                <header>
                    <!-- Status badges -->
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>

                    <!-- Draft actions -->
                    <button name="action_submit_for_approval" type="object"
                            string="📤 Submit for Approval" class="btn-primary"
                            invisible="status != 'draft'"
                            data-hotkey="v"/>

                    <!-- View document button -->
                    <button name="action_view_document" type="object"
                            string="📄 View Document" class="btn-secondary"
                            invisible="not attachment"
                            data-hotkey="d"/>

                    <!-- Negotiation-stage actions: visible only when the
                         linked opportunity is at the Negotiations stage.
                         Note: we cannot use a relational chain like
                         lead_id.stage_id.name in the OWL expression
                         because OWL does not reliably resolve it; the
                         visibility is instead enforced at the method
                         level via _is_in_negotiations(). -->
                    <button name="action_open_negotiation_po_wizard"
                            type="object"
                            string="📧 Send to Client PO"
                            class="btn-primary"
                            invisible="status != 'approved'"
                            groups="dec_crm.group_sales_executive,dec_crm.group_crm_team,dec_crm.group_costing_team"
                            data-hotkey="s"/>
                    <button name="action_request_revision"
                            type="object"
                            string="✏️ Revise"
                            class="btn-secondary"
                            invisible="status != 'approved' or has_lead_pending_revision_request == True"
                            groups="dec_crm.group_sales_executive,dec_crm.group_crm_team"
                            data-hotkey="r"/>
                    <button name="action_replace_quotation_document"
                            type="object"
                            string="📎 Upload Revised Quotation"
                            class="btn-primary"
                            invisible="status != 'draft'"
                            groups="dec_crm.group_costing_team"
                            data-hotkey="u"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="lead_id" readonly="1"/>
                            <field name="revision_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="status" readonly="1"/>
                            <field name="approved_by" readonly="1" invisible="status != 'approved'"/>
                            <field name="approved_date" readonly="1" invisible="status != 'approved'"/>
                        </group>
                    </group>
                    <group string="Document">
                        <field name="attachment" filename="filename" readonly="1" nolabel="1"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <group string="Remarks">
                        <field name="remarks" nolabel="1"/>
                    </group>
                    <!-- Approval Request -->
                    <group string="Approval" invisible="not approval_request_id">
                        <field name="approval_request_id" readonly="1" options='{"no_open": true}'/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DEC QUOTATION — Tree View                                          -->
    <!-- ================================================================== -->
    <record id="dec_quotation_view_tree" model="ir.ui.view">
        <field name="name">dec.quotation.tree</field>
        <field name="model">dec.quotation</field>
        <field name="arch" type="xml">
            <list string="Quotations">
                <field name="name"/>
                <field name="lead_name"/>
                <field name="filename"/>
                <field name="status" widget="badge"
                        decoration-success="status == 'approved'"
                        decoration-warning="status == 'submitted'"
                        decoration-danger="status == 'rejected'"
                        decoration-info="status == 'draft'"/>
                <field name="revision_number"/>
                <field name="approved_by"/>
                <field name="approved_date"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DEC QUOTATION — Search View                                        -->
    <!-- ================================================================== -->
    <record id="dec_quotation_view_search" model="ir.ui.view">
        <field name="name">dec.quotation.search</field>
        <field name="model">dec.quotation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="lead_id"/>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DEC QUOTATION — Action                                             -->
    <!-- ================================================================== -->
    <record id="action_dec_quotation" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">dec.quotation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_status': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No quotations yet.
            </p>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- ACTION: Open Quotations from Lead (Smart Button)                   -->
    <!-- ================================================================== -->
    <record id="action_lead_quotations" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">dec.quotation</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('lead_id', '=', active_id)]</field>
        <field name="context">{'default_lead_id': active_id}</field>
    </record>

    <!-- Link tree view to action -->
    <record id="act_lead_quotations_view_tree" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="action_lead_quotations"/>
        <field name="view_id" ref="dec_quotation_view_tree"/>
    </record>

    <!-- Link form view to action -->
    <record id="act_lead_quotations_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="act_window_id" ref="action_lead_quotations"/>
        <field name="view_id" ref="dec_quotation_view_form"/>
    </record>

</odoo>