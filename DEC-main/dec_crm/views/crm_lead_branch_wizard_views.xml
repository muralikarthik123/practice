<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_crm_lead_branch_wizard" model="ir.actions.act_window">
        <field name="name">Add Branch</field>
        <field name="res_model">crm.lead.branch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_crm_lead_branch_wizard_form" model="ir.ui.view">
        <field name="name">Add Branch</field>
        <field name="model">crm.lead.branch.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Branch">
                <group string="Branch Information">
                    <group string="Contact Details">
                        <field name="name" placeholder="Branch name"/>
                        <field name="contact_person_name" placeholder="Primary contact person"/>
                        <field name="phone" placeholder="Phone number"/>
                        <field name="email" placeholder="Email address"/>
                    </group>
                    <group string="Address">
                        <separator/>
                        <field name="street" placeholder="Street / Address"/>
                        <field name="city" placeholder="City"/>
                        <field name="state_id" placeholder="Select state"/>
                        <field name="zip" placeholder="ZIP code"/>
                        <field name="country_id" placeholder="Select country"/>
                    </group>
                </group>
                <footer>
                    <button name="action_save" string="Save" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
