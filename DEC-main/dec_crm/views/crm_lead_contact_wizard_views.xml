<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_crm_lead_contact_person_wizard" model="ir.actions.act_window">
        <field name="name">Add Contact Person</field>
        <field name="res_model">crm.lead.contact.person.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_crm_lead_contact_person_wizard_form" model="ir.ui.view">
        <field name="name">Add Contact Person</field>
        <field name="model">crm.lead.contact.person.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Contact Person">
                <group string="Contact Details">
                    <group string="Primary Contact">
                        <field name="name" placeholder="Full name"/>
                        <field name="email" placeholder="email@company.com"/>
                    </group>
                    <group string="Additional Info">
                        <field name="phone" placeholder="+91 XXXXX XXXXX"/>
                        <field name="designation" placeholder="e.g., Procurement Manager"/>
                    </group>
                </group>
                <group string="Company Link">
                    <field name="employer_partner_id" string="Company" domain="[('is_company', '=', True)]" placeholder="Select company..."/>
                </group>
                <footer>
                    <button name="action_save" string="Save" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
