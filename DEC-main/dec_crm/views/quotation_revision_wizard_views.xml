<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Revision Wizard Form View -->
    <record id="quotation_revision_wizard_form" model="ir.ui.view">
        <field name="name">quotation.revision.wizard.form</field>
        <field name="model">quotation.revision.wizard</field>
        <field name="arch" type="xml">
            <form string="Revise Quotation">
                <group string="Revision Details">
                    <group string="Quotation">
                        <field name="quotation_id" readonly="1" class="fw-bold"/>
                    </group>
                    <group string="Reason for Revision">
                        <separator/>
                        <field name="revision_reason" placeholder="Explain why this quotation needs revision..."/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_revision" string="Create Revision" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Revision Wizard Action -->
    <record id="quotation_revision_wizard_action" model="ir.actions.act_window">
        <field name="name">Revise Quotation</field>
        <field name="res_model">quotation.revision.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
