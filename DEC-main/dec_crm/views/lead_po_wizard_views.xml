<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- PO ENTRY WIZARD — Form View                                        -->
    <!-- SE enters PO details after client approves quotation               -->
    <!-- ================================================================== -->
    <record id="view_crm_lead_po_wizard_form" model="ir.ui.view">
        <field name="name">dec.crm.lead.po.wizard.form</field>
        <field name="model">dec.crm.lead.po.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter Client PO Details">
                <group string="Sale Order Reference">
                    <group>
                        <field name="lead_id" invisible="1"/>
                        <field name="lead_name" string="Opportunity" readonly="1" class="fw-bold"/>
                        <field name="sale_order_id" invisible="1"/>
                        <field name="so_name" string="SO Reference" readonly="1"/>
                        <field name="partner_id" string="Customer" readonly="1"/>
                        <field name="amount_total" string="Quotation Value" readonly="1"/>
                    </group>
                    <group string="PO Details">
                        <separator/>
                        <field name="po_number" string="Client PO Number" required="1" placeholder="Enter PO number..."/>
                        <field name="po_date" string="Client PO Date" required="1" placeholder="Select PO date..."/>
                        <field name="po_filename" invisible="1"/>
                        <field name="po_document" string="Client PO Document" filename="po_filename"/>
                    </group>
                </group>
                <group string="Remarks">
                    <field name="remarks" nolabel="1" placeholder="Any additional notes about this PO..."/>
                </group>
                <group string="CC — Higher Officials">
                    <field name="cc_partner_ids"
                           widget="many2many_tags"
                           placeholder="Pick additional higher officials to CC (e.g. Sales Head, BH, MH, VH)..."
                           nolabel="1"/>
                    <field name="cc_message"
                           nolabel="1"
                           placeholder="Optional note included in the mail to the CC recipients..."/>
                </group>
                <footer>
                    <button name="action_submit_po" string="Submit PO" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the PO wizard -->
    <record id="action_crm_lead_po_wizard" model="ir.actions.act_window">
        <field name="name">Enter Client PO</field>
        <field name="res_model">dec.crm.lead.po.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_crm_lead_po_wizard_form"/>
    </record>

</odoo>
