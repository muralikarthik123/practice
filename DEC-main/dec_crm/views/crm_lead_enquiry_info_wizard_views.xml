<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_crm_lead_enquiry_info_wizard" model="ir.actions.act_window">
        <field name="name">Enquiry Info Received</field>
        <field name="res_model">crm.lead.enquiry.info.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_crm_lead_enquiry_info_wizard_form" model="ir.ui.view">
        <field name="name">Enquiry Info Received</field>
        <field name="model">crm.lead.enquiry.info.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Enquiry Documents">
                <group string="Enquiry Details">
                    <group string="Lead">
                        <field name="lead_name" readonly="1" class="fw-bold"/>
                    </group>
                    <group string="Remarks">
                        <field name="remarks" placeholder="Optional remarks about the enquiry..."/>
                    </group>
                </group>
                <group string="Documents">
                    <field name="document_ids" widget="many2many_binary" nolabel="1" colspan="2"
                           options="{'accepted_file_extensions': '.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png'}"/>
                </group>
                <footer>
                    <button name="action_confirm_and_move_to_qrf" string="Confirm &amp; Move to QRF" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
