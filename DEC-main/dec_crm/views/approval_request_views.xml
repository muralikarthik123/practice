<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- APPROVAL REQUEST — EXTEND FORM VIEW (Add Line Items Tabs)           -->
    <!-- ================================================================== -->
    <record id="dec_approval_request_view_form" model="ir.ui.view">
        <field name="name">approval.request.form.dec</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">

            <!-- ============================================================ -->
            <!-- ADD LINKED RECORD FIELDS AFTER NAME                           -->
            <!-- ============================================================ -->
            <xpath expr="//field[@name='name']" position="after">
                <group>
                    <group string="Lead / Opportunity" invisible="not lead_id">
                        <field name="lead_id" readonly="1"/>
                        <field name="lead_partner_id" readonly="1"/>
                        <field name="lead_contact_name" readonly="1"/>
                    </group>
                    <group string="Details" invisible="not lead_id">
                        <field name="lead_site_location" readonly="1"/>
                        <field name="lead_expected_value" readonly="1"/>
                    </group>
                </group>
                <!-- Quotation Reference - only show for Sale Order approval, not QRF -->
                <group invisible="qrf_id or not focus_erp_ref">
                    <group string="Quotation Reference">
                        <field name="focus_erp_ref" readonly="1"/>
                        <field name="transportation" readonly="1"/>
                    </group>
                </group>
                <!-- Client PO Details - only show for Sale Order approval, not QRF -->
                <group string="Client PO" invisible="qrf_id or not client_po_number">
                    <field name="client_po_number" readonly="1"/>
                    <field name="client_po_date" readonly="1"/>
                </group>
                <!-- Advance Payment - only show for Sale Order approval, not QRF -->
                <group string="Advance Payment" invisible="qrf_id or not advance_payment_received">
                    <field name="advance_payment_received" readonly="1"/>
                    <field name="advance_payment_amount" readonly="1" invisible="not advance_payment_received"/>
                    <field name="advance_payment_date" readonly="1" invisible="not advance_payment_received"/>
                </group>
                <!-- Revision Info - only show for Sale Order approval, not QRF -->
                <group string="Revision Info" invisible="qrf_id or not original_quotation_id">
                    <field name="original_quotation_id" readonly="1"/>
                    <field name="revision_reason" readonly="1"/>
                </group>
            </xpath>

            <!-- ============================================================ -->
            <!-- ADD QRF LINE ITEMS TAB                                        -->
            <!-- ============================================================ -->
            <xpath expr="//page[last()]" position="after">
                <page string="QRF Line Items" name="qrf_line_items"
                      invisible="not qrf_id">
                    <group>
                        <group string="QRF Summary">
                            <field name="qrf_amount" readonly="1"/>
                        </group>
                    </group>
                    <field name="qrf_line_ids" readonly="1">
                        <list>
                            <field name="product_id"/>
                            <field name="description"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="special_requirements"/>
                            <!-- Windows/Doors fields -->
                            <field name="window_type" invisible="not show_windows_fields"/>
                            <field name="dimensions" invisible="not show_windows_fields"/>
                            <field name="material" invisible="not show_windows_fields"/>
                            <field name="glass_type" invisible="not show_windows_fields"/>
                            <!-- Panels fields -->
                            <field name="panel_type" invisible="not show_panels_fields"/>
                            <field name="voltage_rating" invisible="not show_panels_fields"/>
                            <!-- PEB fields -->
                            <field name="building_type" invisible="not show_peb_fields"/>
                            <field name="total_area_sqm" invisible="not show_peb_fields"/>
                        </list>
                    </field>
                    <!-- QRF Attachments -->
                    <group string="Attachments">
                        <field name="qrf_attachment_ids" readonly="1" widget="many2many_binary"/>
                    </group>
                </page>
            </xpath>

            <!-- ============================================================ -->
            <!-- ADD ENQUIRY DOCUMENTS TAB                                     -->
            <!-- ============================================================ -->
            <xpath expr="//page[last()]" position="after">
                <page string="Enquiry Documents" name="enquiry_documents"
                      invisible="not enquiry_document_attachment_ids">
                    <group string="Enquiry Documents">
                        <field name="enquiry_document_attachment_ids" readonly="1" widget="many2many_binary"/>
                    </group>
                </page>
            </xpath>

            <!-- ============================================================ -->
            <!-- ADD QUOTATION LINE ITEMS TAB                                  -->
            <!-- ============================================================ -->
            <xpath expr="//page[last()]" position="after">
                <page string="Quotation Line Items" name="so_line_items"
                      invisible="not sale_order_id">
                    <field name="so_line_ids" readonly="1">
                        <list>
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <!-- ============================================================ -->
            <!-- ADD QUOTATION DOCUMENT TAB                                    -->
            <!-- ============================================================ -->
            <xpath expr="//page[last()]" position="after">
                <page string="Quotation Document" name="quotation_document"
                      invisible="not quotation_id">
                    <group>
                        <group string="Quotation Details">
                            <field name="quotation_id" readonly="1"/>
                            <field name="quotation_filename" readonly="1"/>
                            <field name="quotation_status" readonly="1"/>
                        </group>
                        <group string="Document">
                            <button name="action_view_quotation_document" type="object"
                                    string="📄 View/Download Quotation" class="btn-primary"
                                    invisible="not quotation_id"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <!-- ============================================================ -->
            <!-- ADD APPROVE/REJECT/REVISE BUTTONS FOR QUOTATION            -->
            <!-- ============================================================ -->
            <xpath expr="//header" position="inside">
                <!-- Approve button for Quotation -->
                <button name="action_approve" type="object"
                        string="✅ Approve" class="btn-success"
                        invisible="not quotation_id or request_status != 'pending'"
                        data-hotkey="v"/>
                <!-- Reject button for Quotation -->
                <button name="action_reject" type="object"
                        string="❌ Reject" class="btn-danger"
                        invisible="not quotation_id or request_status != 'pending'"
                        data-hotkey="r"/>
                <!-- Revise button for Quotation - opens wizard -->
                <button name="%(dec_crm.action_quotation_revise_wizard)d" type="action"
                        string="🔄 Revise" class="btn-warning"
                        invisible="not quotation_id or request_status != 'pending'"
                        context="{'active_id': id}"
                        data-hotkey="e"/>
            </xpath>

        </field>
    </record>

</odoo>