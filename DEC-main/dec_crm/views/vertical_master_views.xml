<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- PRODUCT VERTICAL MASTER - List View                                -->
    <!-- ================================================================== -->
    <record id="dec_product_vertical_view_tree" model="ir.ui.view">
        <field name="name">dec.product.vertical.tree</field>
        <field name="model">dec.product.vertical</field>
        <field name="arch" type="xml">
            <list string="Product Verticals">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="vertical_type"/>
                <field name="uom_id"/>
                <field name="sales_executive_ids" widget="many2many_tags" optional="show"/>
                <field name="color" widget="color_picker"/>
                <field name="qrf_approval_category_id" optional="show"/>
                <field name="quotation_approval_category_id" optional="hide"/>
                <field name="revision_approval_category_id" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- PRODUCT VERTICAL MASTER - Form View                                 -->
    <!-- ================================================================== -->
    <record id="dec_product_vertical_view_form" model="ir.ui.view">
        <field name="name">dec.product.vertical.form</field>
        <field name="model">dec.product.vertical</field>
        <field name="arch" type="xml">
            <form string="Product Vertical">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_approval_categories"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-plus-square"
                                string="Create Approval Categories"
                                help="Create QRF, Quotation, and Revision approval categories for this vertical"/>
                    </div>
                    <notebook>
                        <!-- ── Tab 1: General Info ───────────────────────── -->
                        <page string="General Info" name="general_info">
                            <group string="Vertical Details">
                                <field name="name"/>
                                <field name="code"/>
                                <field name="vertical_type"/>
                                <field name="uom_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group string="Vertical Heads">
                                <field name="vertical_head_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            </group>
                            <group string="Sales Executives">
                                <field name="sales_executive_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            </group>
                            <group string="Approval Categories (Auto-Created)">
                                <field name="qrf_approval_category_id" readonly="1"/>
                                <field name="quotation_approval_category_id" readonly="1"/>
                                <field name="revision_approval_category_id" readonly="1"/>
                            </group>
                            <group string="Appearance">
                                <field name="color" widget="color_picker"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                        </page>

                        <!-- ── Tab 2: Field Configuration ───────────────── -->
                        <page string="Field Configuration" name="field_config">
                            <p class="text-muted o_form_label">
                                Define the groups and fields that appear in the
                                <strong>Vertical Requirements</strong> section of the QRF
                                when this vertical is selected. Add a group first,
                                then click <strong>✏️ Edit Fields</strong> on that group
                                to add fields inside it.
                            </p>
                            <field name="field_group_ids">
                                <list string="Field Groups" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"
                                           placeholder="e.g. 1. Project &amp; Location"
                                           string="Group Name"/>
                                    <field name="field_count"
                                           string="No. of Fields"
                                           readonly="1"/>
                                    <button name="action_open_group_form"
                                            type="object"
                                            icon="fa-pencil"
                                            string="Edit Fields"
                                            class="btn-secondary btn-sm"
                                            help="Open this group to add or edit its fields"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- PRODUCT VERTICAL MASTER - Search View                               -->
    <!-- ================================================================== -->
    <record id="dec_product_vertical_view_search" model="ir.ui.view">
        <field name="name">dec.product.vertical.search</field>
        <field name="model">dec.product.vertical</field>
        <field name="arch" type="xml">
            <search string="Search Verticals">
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- PRODUCT VERTICAL MASTER - Action + Menu                             -->
    <!-- ================================================================== -->
    <record id="action_dec_product_vertical" model="ir.actions.act_window">
        <field name="name">Product Verticals</field>
        <field name="res_model">dec.product.vertical</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <!-- Link list view to action -->
    <record id="act_dec_product_vertical_view_tree" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="action_dec_product_vertical"/>
        <field name="view_id" ref="dec_product_vertical_view_tree"/>
    </record>

    <!-- Link form view to action -->
    <record id="act_dec_product_vertical_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="act_window_id" ref="action_dec_product_vertical"/>
        <field name="view_id" ref="dec_product_vertical_view_form"/>
    </record>

    <!-- Verticals menu - accessible by Sales Exec, CRM Team, Vertical Head, Business Head -->
    <menuitem id="menu_dec_product_vertical"
              name="Verticals"
              action="action_dec_product_vertical"
              parent="crm.crm_menu_root"
              sequence="10"
              groups="dec_crm.group_sales_executive,dec_crm.group_crm_team,dec_crm.group_vertical_head,dec_crm.group_business_head,dec_crm.group_ceo"/>

</odoo>