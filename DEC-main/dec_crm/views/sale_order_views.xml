<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- SALE ORDER — FORM VIEW EXTENSION (Odoo Native Approvals + V3 Fields) -->
    <!-- ================================================================== -->
    <record id="dec_sale_order_view_form" model="ir.ui.view">
        <field name="name">sale.order.form.dec</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Hidden field: approval request link (for visibility conditions) -->
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="approval_request_id" invisible="1"/>
            </xpath>

            <!-- ============================================================ -->
            <!-- HEADER: Odoo Native Approvals buttons                         -->
            <!-- ============================================================ -->
            <xpath expr="//button[@name='action_quotation_send']" position="before">

                <!-- Request Approval — Costing Team -->
                <button name="action_request_approval" type="object"
                        string="📤 Request Approval" class="btn-primary"
                        invisible="approval_request_id"
                        groups="dec_crm.group_costing_team"/>

                <!-- View Approval Request — anyone -->
                <button name="action_view_approval_request" type="object"
                        string="🔍 View Approval Request" class="btn-secondary"
                        invisible="not approval_request_id"
                        groups="dec_crm.group_costing_team,dec_crm.group_vertical_head,dec_crm.group_business_head,dec_crm.group_marketing_head,dec_crm.group_ceo"/>

                <!-- Verify PO & Confirm Order — Costing Team -->
                <button name="action_verify_po_confirm_order" type="object"
                        string="✅ Verify PO &amp; Confirm Order" class="btn-success"
                        invisible="not client_po_number or po_verified == True"
                        groups="dec_crm.group_costing_team"/>

                <!-- Revise Quotation — opens wizard to create new revision -->
                <button name="action_open_revision_wizard" type="object"
                        string="🔄 Revise Quotation" class="btn-warning"
                        invisible="not approval_request_id or approval_request_id.request_status not in ('approved', 'refused')"
                        groups="dec_crm.group_costing_team"/>

                <!-- Quotation Accepted — opens PO wizard -->
                <button name="action_open_po_wizard" type="object"
                        string="✅ Quotation Accepted" class="btn-success"
                        invisible="approval_request_id and approval_request_id.request_status != 'approved'"
                        groups="dec_crm.group_costing_team"/>

            </xpath>

            <!-- Hide Send/Confirm unless quotation is approved -->
            <xpath expr="//button[@name='action_quotation_send']" position="attributes">
                <attribute name="invisible">approval_request_id and approval_request_id.request_status != 'approved'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">approval_request_id and approval_request_id.request_status != 'approved'</attribute>
            </xpath>

            <!-- ============================================================ -->
            <!-- HEADER FIELDS: Revision, Focus ERP                            -->
            <!-- ============================================================ -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="revision_number" readonly="1"/>
                <field name="focus_erp_ref"/>
                <field name="transportation"/>
            </xpath>

            <!-- ============================================================ -->
            <!-- SPECIFICATION column on order lines                          -->
            <!-- ============================================================ -->
            <xpath expr="//field[@name='order_line']/list/field[@name='name']" position="after">
                <field name="specification" optional="hide"/>
            </xpath>

            <!-- ============================================================ -->
            <!-- NOTEBOOK TABS                                                -->
            <!-- ============================================================ -->
            <xpath expr="//notebook" position="inside">

                <!-- Approval Status Tab — Odoo Native Approvals -->
                <page string="Approvals" name="approvals_tab">

                    <!-- Status banners driven by approval_request_id.request_status -->
                    <div class="alert alert-success" role="alert"
                         invisible="not approval_request_id or approval_request_id.request_status != 'approved'">
                        <strong>&#9989; Fully Approved</strong> — Approval request has been approved. Ready to send to customer.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="not approval_request_id or approval_request_id.request_status != 'refused'">
                        <strong>&#10060; Rejected</strong> — Please revise and resubmit.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="not approval_request_id or approval_request_id.request_status != 'pending'">
                        <strong>&#9203; Pending Approval</strong> —
                        Status: <field name="approval_request_id" readonly="1" class="d-inline"
                                       options="{'recognize': True}"/>
                    </div>
                    <div class="alert alert-info" role="alert"
                         invisible="approval_request_id">
                        <strong>Not Submitted</strong> — Click "Request Approval" to submit for BH/MH approval.
                    </div>

                    <!-- Link to open approval request form -->
                    <group invisible="not approval_request_id">
                        <group string="Approval Request">
                            <field name="approval_request_id"
                                   readonly="1"
                                   options="{'no_open': True}"/>
                        </group>
                        <!-- Revision Tracking -->
                        <group string="Revision Info" invisible="not original_quotation_id">
                            <field name="original_quotation_id" readonly="1" options="{'no_open': True}"/>
                            <field name="revision_reason" readonly="1"/>
                        </group>
                    </group>

                </page>

                <!-- Inspection & Transport -->
                <page string="Inspection &amp; Delivery" name="inspection_tab">
                    <group>
                        <group string="Transportation">
                            <field name="transportation"/>
                        </group>
                    </group>
                    <group string="Inspection Notes">
                        <field name="inspection_notes" nolabel="1" colspan="2"
                               placeholder="Inspection requirements and notes..."/>
                    </group>
                </page>

                <!-- Client PO & Payment (V3 — Not required) -->
                <page string="Client PO &amp; Payment" name="client_po_tab">
                    <group>
                        <group string="Client Purchase Order">
                            <field name="client_po_number"/>
                            <field name="client_po_date"/>
                            <field name="client_po_attachment" filename="client_po_filename"/>
                            <field name="client_po_filename" invisible="1"/>
                        </group>
                        <group string="Advance Payment">
                            <field name="advance_payment_received"/>
                            <field name="advance_payment_amount"
                                   invisible="not advance_payment_received"/>
                            <field name="advance_payment_date"
                                   invisible="not advance_payment_received"/>
                        </group>
                    </group>
                </page>

            </xpath>

        </field>
    </record>

</odoo>
