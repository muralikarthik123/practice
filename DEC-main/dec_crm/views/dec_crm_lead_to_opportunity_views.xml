<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- DEC Convert to Opportunity - Single Wizard for All Cases              -->
    <!-- Shown when: no partner (Create Company flow) OR partner found      -->
    <!-- (Refresh to re-check). Shows appropriate buttons per state.           -->
    <!-- ================================================================== -->
    <record id="dec_crm_lead2opportunity_partner_form" model="ir.ui.view">
        <field name="name">dec.crm.lead.to.opportunity.form</field>
        <field name="model">dec.crm.lead.to.opportunity</field>
        <field name="arch" type="xml">
            <form string="Convert to Opportunity">
                <!-- Hidden fields for context -->
                <field name="lead_id" invisible="1"/>

                <group>
                    <group string="Sales Team Assignment">
                        <field name="user_id" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                        <field name="team_id" options="{'no_open': True, 'no_create': True}" context="{'kanban_view_ref': 'sales_team.crm_team_view_kanban'}"/>
                    </group>
                    <group string="Customer">
                        <!-- partner_id shown only when partner found -->
                        <field name="partner_id"
                               widget="res_partner_many2one"
                               context="{'res_partner_search_mode': 'customer', 'show_vat': True}"
                               invisible="not partner_id"
                               readonly="1"
                               placeholder="Search and select existing customer..."/>
                        <!-- Warning shown when no partner found -->
                        <div class="alert alert-warning" role="alert" colspan="2" invisible="partner_id">
                            <strong>Company not found.</strong><br/>
                            If the company doesn't exist yet, click
                            <strong>Create Company</strong> to add it.
                            After saving the company, <strong>reopen this wizard</strong>
                            and the company will be auto-detected.
                        </div>
                    </group>
                </group>

                <footer>
                    <!-- No partner: Create Company + Close -->
                    <button name="action_create_company" string="Create Company" type="object" class="btn-primary"
                            invisible="partner_id"/>
                    <button name="action_close" string="Cancel" type="object" class="btn-secondary"
                            invisible="partner_id"/>

                    <!-- Refresh button if partner not found after creating company -->
                    <button name="action_refresh_partner" string="Refresh" type="object" class="btn-secondary" icon="fa-refresh"
                            invisible="partner_id"/>

                    <!-- Partner found: Convert + Close -->
                    <button name="action_convert" string="Create Opportunity" type="object" class="btn-primary"
                            invisible="not partner_id"/>
                    <button name="action_close" string="Cancel" type="object" class="btn-secondary"
                            invisible="not partner_id"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the DEC Convert wizard -->
    <record id="dec_crm.action_crm_lead2opportunity_partner" model="ir.actions.act_window">
        <field name="name">Convert to opportunity</field>
        <field name="res_model">dec.crm.lead.to.opportunity</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="dec_crm.dec_crm_lead2opportunity_partner_form"/>
        <field name="target">new</field>
    </record>
</odoo>
