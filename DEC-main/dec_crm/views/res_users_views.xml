<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- RES.USERS — FORM VIEW EXTENSION                                     -->
    <!-- Add DEC Role and Team fields to user settings form                   -->
    <!-- ================================================================== -->
    <record id="dec_res_users_view_form" model="ir.ui.view">
        <field name="name">res.users.form.dec</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Add DEC CRM Settings section before the Access Rights groups -->
            <xpath expr="//page[@name='access_rights']" position="before">
                <page string="DEC CRM" name="dec_crm_settings">
                    <group>
                        <group string="DEC Role &amp; Team">
                            <field name="dec_role"/>
                            <field name="dec_team_id"/>
                        </group>
                        <group string="Assignment Preferences">
                            <field name="vertical_ids"
                                   widget="many2many_tags"
                                   placeholder="Select verticals..."
                                   invisible="dec_role not in ('sales_executive', 'design_reviewer')"/>
                            <field name="state_id"
                                   placeholder="Select state/region..."
                                   invisible="dec_role != 'sales_executive'"/>
                        </group>
                        <group string="Info">
                            <div class="text-muted" colspan="2">
                                <p><strong>How it works:</strong></p>
                                <ul>
                                    <li>Selecting a DEC Role will auto-assign the correct Odoo security groups.</li>
                                    <li>Selecting a DEC Sales Team will auto-add this user as a team member.</li>
                                    <li>Verticals and State are used for smart lead auto-assignment.</li>
                                    <li>Role changes are tracked in the user's audit log.</li>
                                </ul>
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
