<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- DEC ESCALATION — TREE / SEARCH                                  -->
    <!-- ============================================================== -->
    <record id="view_dec_escalation_tree" model="ir.ui.view">
        <field name="name">dec.escalation.list</field>
        <field name="model">dec.escalation</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'open'"
                  decoration-warning="state == 'acknowledged'"
                  decoration-muted="state == 'resolved'">
                <field name="name"/>
                <field name="level"/>
                <field name="lead_id" readonly="0"/>
                <field name="stage_at_trigger"/>
                <field name="assigned_user_id"/>
                <field name="stalled_minutes" string="Stalled (min)"/>
                <field name="state"/>
                <field name="sent_date"/>
                <field name="acknowledged_date" optional="hide"/>
                <field name="resolved_date" optional="hide"/>
                <button name="action_open_lead" string="Open Lead"
                        type="object" icon="fa-external-link"/>
            </list>
        </field>
    </record>

    <record id="view_dec_escalation_search" model="ir.ui.view">
        <field name="name">dec.escalation.search</field>
        <field name="model">dec.escalation</field>
        <field name="arch" type="xml">
            <search string="Search Escalations">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="assigned_user_id"/>
                <field name="level"/>
                <field name="state"/>
                <field name="stage_at_trigger"/>
                <separator/>
                <filter name="filter_open"
                        string="Open"
                        domain="[('state', '=', 'open')]"/>
                <filter name="filter_acknowledged"
                        string="Acknowledged"
                        domain="[('state', '=', 'acknowledged')]"/>
                <filter name="filter_resolved"
                        string="Resolved"
                        domain="[('state', '=', 'resolved')]"/>
                <separator/>
                <filter name="filter_L1"
                        string="L1 — Business Head"
                        domain="[('level', '=', 'L1')]"/>
                <filter name="filter_L2"
                        string="L2 — Marketing Head"
                        domain="[('level', '=', 'L2')]"/>
                <filter name="filter_L3"
                        string="L3 — CEO"
                        domain="[('level', '=', 'L3')]"/>
                <separator/>
                <filter name="filter_sub_lead"
                        string="Sub-Lead Escalations"
                        domain="[('is_sub_lead', '=', True)]"/>
            </search>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- DEC ESCALATION — FORM                                           -->
    <!-- ============================================================== -->
    <record id="view_dec_escalation_form" model="ir.ui.view">
        <field name="name">dec.escalation.form</field>
        <field name="model">dec.escalation</field>
        <field name="arch" type="xml">
            <form string="DEC Escalation">
                <header>
                    <button name="action_open_lead"
                            string="Open Lead"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_acknowledge"
                            string="Acknowledge"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'open'"/>
                    <button name="action_resolve_manually"
                            string="Resolve Manually"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'resolved'"
                            groups="dec_crm.group_business_head,dec_crm.group_marketing_head,dec_crm.group_ceo"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="open,acknowledged,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Escalation">
                            <field name="level" widget="badge"
                                   decoration-info="level == 'L1'"
                                   decoration-warning="level == 'L2'"
                                   decoration-danger="level == 'L3'"/>
                            <field name="lead_id" readonly="0"/>
                            <field name="parent_lead_id"
                                   invisible="not is_sub_lead"/>
                            <field name="is_sub_lead" invisible="1"/>
                            <field name="stage_at_trigger"/>
                            <field name="stalled_at"/>
                            <field name="stalled_minutes"/>
                        </group>
                        <group string="Recipients">
                            <field name="assigned_user_id"/>
                            <field name="cc_partner_ids"
                                   widget="many2many_tags"/>
                            <field name="sent_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Acknowledgment"
                               invisible="not acknowledged_date">
                            <field name="acknowledged_date"/>
                            <field name="acknowledged_by"/>
                        </group>
                        <group string="Resolution"
                               invisible="not resolved_date">
                            <field name="resolved_date"/>
                            <field name="resolved_by"/>
                            <field name="resolved_reason"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activities"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- ACTIONS                                                         -->
    <!-- ============================================================== -->
    <!--
        My Escalations — visible to all users. Domain filters by user role:
        - assigned_user_id = me (for BH/MH escalations assigned to me)
        - OR lead.user_id = me (salesperson on the lead)
        - OR lead.claimed_by = me (CRM claimer on the lead)
        - OR lead.design_user_id = me (Design Reviewer on the lead)
        - OR lead.costing_user_id = me (Costing user on the lead)
        - OR lead.vh_user_id = me (Vertical Head on the lead)
    -->
    <record id="action_dec_escalation_my" model="ir.actions.act_window">
        <field name="name">My Escalations</field>
        <field name="res_model">dec.escalation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            '|', '|', '|', '|', '|',
            ('assigned_user_id', '=', uid),
            ('lead_id.user_id', '=', uid),
            ('lead_id.claimed_by', '=', uid),
            ('lead_id.design_user_id', '=', uid),
            ('lead_id.costing_user_id', '=', uid),
            ('lead_id.vh_user_id', '=', uid)
        ]</field>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>

    <!--
        All Escalations — restricted to managers (BH/MH/CRM Team+) at the
        menu level (see dec_crm_menus.xml). The record rules already
        limit data access per role.
    -->
    <record id="action_dec_escalation_all" model="ir.actions.act_window">
        <field name="name">All Escalations</field>
        <field name="res_model">dec.escalation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>

    <record id="action_dec_escalation_sub_lead" model="ir.actions.act_window">
        <field name="name">Sub-Lead Escalations</field>
        <field name="res_model">dec.escalation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_sub_lead', '=', True)]</field>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>

</odoo>