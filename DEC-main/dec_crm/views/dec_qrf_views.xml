<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- QRF — Standalone Form View                                          -->
    <!-- ================================================================== -->
    <record id="dec_qrf_view_form" model="ir.ui.view">
        <field name="name">dec.qrf.form</field>
        <field name="model">dec.qrf</field>
        <field name="arch" type="xml">
            <form string="QRF Form" edit="true">
                <header>
                    <!-- Sales Executive: Submit (draft only) -->
                    <button name="action_submit_qrf" type="object"
                            string="Submit QRF" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Submit this QRF? It will be sent to the Vertical Head for approval and cannot be undone."
                            groups="dec_crm.group_sales_executive"/>
                    <!-- Sales Executive: Reset to Draft after refusal so they can correct and resubmit -->
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft (Resubmit)" class="btn-warning"
                            invisible="state != 'rejected'"
                            confirm="Reset this QRF to Draft? You will be able to edit and resubmit it for approval."
                            groups="dec_crm.group_sales_executive"/>
                    <!-- Vertical Head: Approve QRF directly from dec.qrf form -->
                    <button name="action_approve_qrf" type="object"
                            string="Approve QRF" class="btn-success"
                            invisible="state != 'pending_approval'"
                            confirm="Approve this QRF? This will mark it as approved and notify the Sales Executive."
                            groups="dec_crm.group_vertical_head"/>
                    <!-- Vertical Head: Refuse with reason wizard -->
                    <button name="action_open_refuse_wizard" type="object"
                            string="Refuse QRF" class="btn-danger"
                            invisible="state != 'pending_approval'"
                            groups="dec_crm.group_vertical_head"/>
                    <!-- View Approval Request (non-SE roles) -->
                    <button name="action_view_approval_request" type="object"
                            string="View Approval Request" class="btn-secondary"
                            invisible="not approval_request_id"
                            groups="dec_crm.group_costing_team,dec_crm.group_vertical_head,dec_crm.group_business_head,dec_crm.group_marketing_head,dec_crm.group_ceo"/>
                    <!-- Design Reviewer: Claim this QRF when no DR matched the vertical -->
                    <button name="action_claim_design_review" type="object"
                            string="Claim (Design Review)" class="btn-warning"
                            invisible="not is_design_review_claimable"
                            confirm="Claim this QRF for Design Review? It will be assigned to you."
                            groups="dec_crm.group_design_reviewer"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="QRF Details">
                            <field name="name" readonly="1"/>
                            <field name="lead_id" readonly="1"/>
                            <field name="date"/>
                            <field name="product_vertical_ids"
                                   placeholder="Select vertical..."
                                   domain="[('id', 'in', allowed_vertical_ids)]"
                                   help="Select the vertical for this QRF. One QRF is required per vertical: Windows, Doors, Panels, or PEB. Each vertical must be submitted separately."/>
                            <field name="needs_design_review"
                                   widget="boolean_toggle"
                                   help="If checked, the lead will require Design Review after QRF approval."/>
                        </group>
                        <group string="Commercial">
                            <field name="currency_id" readonly="1"/>
                            <field name="amount_total" readonly="1" string="QRF Estimated Total"/>
                        </group>
                        <group string="Site Info">
                            <field name="site_address"/>
                            <field name="submitted_by" readonly="1"/>
                            <field name="submitted_date" readonly="1"/>
                        </group>
                        <group string="Design Review" invisible="not needs_design_review">
                            <field name="design_user_id" readonly="1"/>
                            <field name="design_reviewer_claim_state" readonly="1" widget="badge"
                                   decoration-warning="design_reviewer_claim_state == 'unclaimed'"
                                   decoration-success="design_reviewer_claim_state == 'claimed'"/>
                        </group>
                    </group>

                    <field name="has_windows_doors" invisible="1"/>
                    <field name="has_panels" invisible="1"/>
                    <field name="has_peb" invisible="1"/>
                    <field name="allowed_vertical_ids" invisible="1"/>
                    <field name="approval_request_id" invisible="1"/>
                    <field name="can_edit_lines" invisible="1"/>
                    <field name="is_design_review_claimable" invisible="1"/>

                    <notebook>
                        <page string="Line Items" name="qrf_lines">
                            <field name="line_ids" readonly="not can_edit_lines">
                                <list string="QRF Line Items" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="special_requirements"/>

                                    <!-- Windows/Doors fields — user shows/hides via column chooser -->
                                    <field name="window_type" optional="show"/>
                                    <field name="dimensions" optional="show"/>
                                    <field name="material" optional="hide"/>
                                    <field name="glass_type" optional="hide"/>
                                    <field name="glass_thickness" optional="hide"/>
                                    <field name="color_finish" optional="hide"/>
                                    <field name="hardware_type" optional="hide"/>
                                    <field name="mosquito_mesh" optional="hide"/>

                                    <!-- Panels fields -->
                                    <field name="panel_type" optional="show"/>
                                    <field name="voltage_rating" optional="show"/>
                                    <field name="ampere_rating" optional="hide"/>
                                    <field name="switchgear_brand" optional="hide"/>
                                    <field name="ip_rating" optional="hide"/>
                                    <field name="enclosure_type" optional="hide"/>

                                    <!-- PEB fields -->
                                    <field name="building_type" optional="show"/>
                                    <field name="total_area_sqm" optional="show"/>
                                    <field name="clear_span_m" optional="hide"/>
                                    <field name="bay_spacing_m" optional="hide"/>
                                    <field name="building_height_m" optional="hide"/>
                                    <field name="crane_capacity" optional="hide"/>
                                    <field name="roof_type" optional="hide"/>
                                    <field name="wall_cladding" optional="hide"/>
                                    <field name="wind_zone" optional="hide"/>
                                    <field name="seismic_zone" optional="hide"/>
                                </list>
                            </field>

                            <!-- ============================================================ -->
                            <!-- VERTICAL REQUIREMENTS — Dynamic fields from vertical config  -->
                            <!-- Visible only when a vertical with field groups is selected   -->
                            <!-- ============================================================ -->
                            <separator string="Vertical Requirements"
                                       invisible="not product_vertical_ids"/>
                            <field name="dynamic_value_ids"
                                   readonly="not can_edit_lines"
                                   invisible="not product_vertical_ids">
                                <list string="Vertical Requirements"
                                      editable="bottom"
                                      create="false"
                                      delete="false">
                                    <!-- field_definition_id is required; kept invisible so
                                         Odoo includes it in the row payload on save -->
                                    <field name="field_definition_id" column_invisible="1"/>
                                    <field name="group_name"
                                           readonly="1"
                                           string="Group"
                                           optional="show"/>
                                    <field name="field_name"
                                           readonly="1"
                                           string="Field"/>
                                    <field name="field_type"
                                           readonly="1"
                                           string="Type"
                                           widget="badge"
                                           decoration-info="field_type == 'input'"
                                           decoration-success="field_type == 'boolean'"
                                           optional="show"/>
                                    <field name="value_text"
                                           string="Value (Text)"
                                           invisible="field_type != 'input'"
                                           optional="show"/>
                                    <field name="value_boolean"
                                           string="Yes / No"
                                           widget="boolean_toggle"
                                           invisible="field_type != 'boolean'"
                                           optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Design Documents" name="design_documents">
                            <group string="Upload Design Documents">
                                <field name="attachment_ids" widget="many2many_binary" string="Documents" class="oe_inline"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- QRF — Standalone List View -->
    <record id="dec_qrf_view_tree" model="ir.ui.view">
        <field name="name">dec.qrf.list</field>
        <field name="model">dec.qrf</field>
        <field name="arch" type="xml">
            <list string="QRF Forms"
                   decoration-info="state == 'draft'"
                   decoration-warning="state == 'pending_approval'"
                   decoration-success="state == 'approved'"
                   decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="product_vertical_ids" string="Vertical"/>
                <field name="date"/>
                <field name="needs_design_review" string="Design Review?" optional="hide"/>
                <field name="design_user_id" string="Design Reviewer" optional="show"/>
                <field name="amount_total" string="Total"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending_approval'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
                <field name="submitted_by"/>
                <field name="submitted_date"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- QRF — Action for smart button on lead form                          -->
    <!-- ================================================================== -->
    <record id="action_view_qrf_from_lead" model="ir.actions.act_window">
        <field name="name">QRF Forms</field>
        <field name="res_model">dec.qrf</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('lead_id', '=', active_id)]</field>
        <field name="context">{'default_lead_id': active_id, 'force_domain': [('lead_id', '=', active_id)]}</field>
    </record>

    <!-- Link list and form views to QRF action -->
    <record id="act_view_qrf_from_lead_view_tree" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="action_view_qrf_from_lead"/>
        <field name="view_id" ref="dec_qrf_view_tree"/>
    </record>
    <record id="act_view_qrf_from_lead_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="act_window_id" ref="action_view_qrf_from_lead"/>
        <field name="view_id" ref="dec_qrf_view_form"/>
    </record>

</odoo>
