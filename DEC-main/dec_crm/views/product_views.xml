<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- PRODUCT.TEMPLATE - Form View Extension                             -->
    <!-- Add DEC Vertical field to product form                             -->
    <!-- ================================================================== -->
    <record id="dec_product_template_view_form" model="ir.ui.view">
        <field name="name">product.template.form.dec</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Add DEC Verticals field after category -->
            <field name="categ_id" position="after">
                <field name="vertical_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"
                       placeholder="Select verticals (Windows, Doors, PEB, Panels)..."
                       invisible="type == 'service'"/>
            </field>

        </field>
    </record>

</odoo>