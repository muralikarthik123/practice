<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard for VH to request quotation revision -->
    <record id="quotation_revise_wizard_form" model="ir.ui.view">
        <field name="name">quotation.revise.wizard.form</field>
        <field name="model">quotation.revise.wizard</field>
        <field name="arch" type="xml">
            <form string="Request Quotation Revision">
                <group>
                    <group>
                        <field name="approval_request_id" invisible="1"/>
                        <field name="quotation_id" invisible="1"/>
                        <field name="quotation_name" string="Quotation" readonly="1" class="fw-bold"/>
                        <field name="lead_name" string="Lead / Opportunity" readonly="1"/>
                    </group>
                </group>
                <group string="What needs to be revised?">
                    <field name="revision_notes" string="Revision Notes" required="1" nolabel="1"
                            placeholder="Describe what corrections or changes are needed..."/>
                </group>
                <footer>
                    <button name="action_request_revision" string="🔄 Request Revision" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_quotation_revise_wizard" model="ir.actions.act_window">
        <field name="name">Request Revision</field>
        <field name="res_model">quotation.revise.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>