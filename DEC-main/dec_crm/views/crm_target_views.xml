<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
        list VIEW
    ====================================================== -->
    <record id="view_crm_targets_list" model="ir.ui.view">
        <field name="name">crm.targets.list</field>
        <field name="model">crm.targets</field>
        <field name="arch" type="xml">
            <list string="Target Reports">
                <field name="name"/>
<!--                <field name="last_month_target"/>-->
<!--                <field name="current_month_achieved"/>-->
                <field name="current_month_target" string="Quarterly/Monthly Target"/>
                <field name="current_month_achieved" string="Quarterly/Monthly Achieved"/>
                <field name="overall_target"/>
                <field name="overall_achieved"/>
            </list>
        </field>
    </record>

    <!-- =====================================================
        FORM VIEW
    ====================================================== -->
    <record id="view_crm_targets_form" model="ir.ui.view">
        <field name="name">crm.targets.form</field>
        <field name="model">crm.targets</field>
        <field name="arch" type="xml">
            <form string="Target Report">

                <header>
                    <button name="refresh_targets"
                            type="object"
                            string="Refresh"
                            class="btn-primary"/>


                    <!-- Update Targets -->
                    <button name="action_update_targets"
                            type="object"
                            string="Targets Locked"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_move_draft"
                            type="object"
                            string="Move to Draft"
                            class="btn-primary"
                            invisible="state == 'draft'"/>

                    <!--year wise report-->
                    <button name="action_download_yearly_manager_report"
                        type="object"
                        string="Download Yearly Manager Report"
                        class="btn-primary"
                        invisible="state == 'draft'"/>

                    <!--month wise report-->
                    <button name="action_download_monthly_manager_report"
                        type="object"
                        string="Download Monthly Manager Report"
                        class="btn-primary"
                        invisible="state == 'draft'"/>

                    <!--Day Wise Reports Downloaded -->
                    <button name="action_download_daywise_report"
                            type="object"
                            string="Day Wise Reports Download"
                            class="btn-primary"
                            invisible="state == 'draft'"/>

                    <!-- manager wise performance report-->
                    <button name="action_download_manager_report"
                            type="object"
                            string="Manager Wise Report"
                            class="btn-primary"
                            invisible="state == 'draft'"/>


                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>

                    <group>
                        <field name="name" readonly="1"/>
<!--                        <field name="date"/>-->
                        <field name="month_date"/>
                        <field name="year" readonly="1"/>
<!--                        <field name="month" readonly="1"/>-->
                    </group>

                    <!-- ================= NOTEBOOK ================= -->
                    <notebook>

                        <!-- ================= SALES PAGE ================= -->
                        <page string="Sales">

                            <field name="sales_line_ids">

                                <list create="0" delete="0">
                                    <field name="user_id"/>
                                    <field name="last_month_target" readonly="1"/>
                                    <field name="last_month_achieved" readonly="1"/>
                                    <field name="previous_month_pending" readonly="1"/>
                                    <field name="current_month_target"/>
                                    <field name="current_month_achieved" readonly="1"/>
                                    <field name="display_target" readonly="1"/>

                                    <field name="overall_target" readonly="1"/>
                                    <field name="overall_achieved" readonly="1"/>

                                </list>

                                <form>
                                    <group>
                                        <field name="user_id"  readonly="1"/>
                                        <field name="current_month_target"  readonly="1"/>
                                        <field name="current_month_achieved" readonly="1"/>
                                    </group>

                                    <notebook>

                                        <page string="Vertical">
                                            <field name="vertical_line_ids">
                                                <list editable="bottom" create="0" delete="0">
                                                    <field name="vertical_id"/>
                                                    <field name="target" readonly="target_state != 'draft'"/>
                                                    <field name="achieved"/>
                                                </list>
                                            </field>
                                        </page>

                                    </notebook>

                                </form>

                            </field>

                        </page>



                        <!--day wise-->
                        <page string="Day Wise">

                            <field name="daywise_line_ids">

                                <list  create="0" delete="0">
                                    <field name="user_id"/>
                                    <field name="lead_created"/>
                                    <field name="no_of_leads"/>
                                    <field name="enquiries"/>
                                    <field name="qrf_received"/>
                                    <field name="product"/>
                                    <field name="design_submitted"/>
                                    <field name="quotation_sent"/>
                                    <field name="re_quotation"/>
                                    <field name="finalized_orders"/>
                                    <field name="uom"/>
                                    <field name="order_value"/>
                                </list>

                                <form string="Day Wise">

                                    <sheet>

                                        <group>
                                            <field name="user_id" readonly="1"/>
                                        </group>

                                        <notebook>

                                            <page string="Day Wise Entries">

                                                <field name="line_ids">

                                                    <list create="0" delete="0" editable="bottom" >
                                                        <field name="date" readonly="1"/>
                                                        <field name="lead_created" readonly="1"/>
                                                        <field name="no_of_leads" readonly="1"/>
                                                        <field name="enquiries" readonly="1"/>
                                                        <field name="qrf_received" readonly="1"/>
                                                        <field name="product" readonly="1"/>
                                                        <field name="design_submitted" readonly="1"/>
                                                        <field name="quotation_sent" readonly="1"/>
                                                        <field name="re_quotation" readonly="1"/>
                                                        <field name="finalized_orders" readonly="1"/>
                                                        <field name="uom" readonly="1"/>
                                                        <field name="order_value" readonly="1"/>
                                                    </list>

<!--                                                    <form string="Day Wise Line">-->
<!--                                                        <field name="product_summary_ids">-->
<!--                                                            <list create="0" delete="0">-->
<!--                                                                <field name="product_id" readonly="1"/>-->
<!--                                                                <field name="no_of_visits"/>-->
<!--                                                                <field name="no_of_leads"/>-->
<!--                                                                <field name="enquiries"/>-->
<!--                                                                <field name="qrf_received"/>-->
<!--                                                                <field name="design_submitted"/>-->
<!--                                                                <field name="quotation_sent"/>-->
<!--                                                                <field name="re_quotation"/>-->
<!--                                                                <field name="finalized_orders"/>-->
<!--                                                                <field name="uom"/>-->
<!--                                                                <field name="order_value"/>-->
<!--                                                            </list>-->
<!--                                                        </field>-->
<!--                                                    </form>-->

                                                </field>

                                            </page>

                                        </notebook>

                                    </sheet>

                                </form>

                            </field>

                        </page>

                        <!-- manager performance tab-->
                        <page string="Manager performance" name="manager_performance">
                            <field name="manager_performance_ids">
                                <list create="0" delete="0">
                                    <field name="sales_manager_id"/>
                                    <field name="leads_assigned"/>
                                    <field name="no_of_leads"/>
                                    <field name="opportunity_count"/>
                                    <field name="quotation_count"/>
                                    <field name="won_deals"/>
                                    <field name="lost_deals"/>
                                    <field name="conversion_rate" string="Conversion %" widget="percentage"/>
                                    <field name="revenue_won"/>
                                </list>
                                <form string="Manager Performance">
                                    <sheet>
                                        <group>
                                             <field name="sales_manager_id" readonly="1" options="{'no_open': True}"/>
                                        </group>


                                        <notebook>
                                            <page string="CRM Team" name="crm_team">
                                                <field name="crm_team_ids">
                                                    <list editable="bottom" create="0" delete="0">
                                                        <field name="assigned_by" readonly="1" />
                                                        <field name="leads_assigned" readonly="1"/>
                                                        <field name="no_of_leads"  readonly="1"/>
                                                        <field name="opportunity_count" readonly="1" />
                                                        <field name="quotation_count" readonly="1"/>
                                                        <field name="won_deals" readonly="1"/>
                                                        <field name="lost_deals" readonly="1"/>
                                                        <field name="conversion_rate" widget="percentage" readonly="1"/>
                                                        <field name="revenue_won" readonly="1"/>
                                                    </list>
                                                </field>
                                            </page>

                                            <page string="Sales" name="sales">
                                                <field name="sales_ids">
                                                    <list editable="bottom" create="0" delete="0">
                                                        <field name="assigned_by" readonly="1" />
                                                        <field name="leads_assigned" readonly="1" />
                                                        <field name="no_of_leads"  readonly="1"/>
                                                        <field name="opportunity_count" readonly="1" />
                                                        <field name="quotation_count" readonly="1" />
                                                        <field name="won_deals" readonly="1" />
                                                        <field name="lost_deals" readonly="1" />
                                                        <field name="conversion_rate" widget="percentage" readonly="1" />
                                                        <field name="revenue_won" readonly="1" />
                                                    </list>
                                                </field>
                                            </page>

                                            <page string="Cross Sell" name="cross_sell">
                                                <field name="cross_sell_ids">
                                                    <list editable="bottom" create="0" delete="0">
                                                        <field name="assigned_by" readonly="1" />
                                                        <field name="leads_assigned" readonly="1" />
                                                        <field name="no_of_leads"  readonly="1"/>
                                                        <field name="opportunity_count" readonly="1" />
                                                        <field name="quotation_count" readonly="1" />
                                                        <field name="won_deals" readonly="1" />
                                                        <field name="lost_deals" readonly="1" />
                                                        <field name="conversion_rate" widget="percentage" readonly="1" />
                                                        <field name="revenue_won" readonly="1" />
                                                    </list>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>





                        <!-- day wise reports starts-->
                        <!-- ================= NOTES PAGE ================= -->
                        <page string="Notes">
                            <field name="notes"/>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <!-- =====================================================
        ACTION
    ====================================================== -->
    <record id="action_crm_targets" model="ir.actions.act_window">
        <field name="name">Target Reports</field>
        <field name="res_model">crm.targets</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Sub Menu: Target Reports -->
    <menuitem id="menu_crm_target_reports"
          name="Target Reports"
          parent="crm.crm_menu_report"
          action="action_crm_targets"
          sequence="10"
          groups="group_crm_team"/>

</odoo>