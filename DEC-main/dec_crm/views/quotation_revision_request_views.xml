<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- QUOTATION REVISION REQUEST — Form View                                -->
    <!-- ================================================================== -->
    <record id="quotation_revision_request_view_form" model="ir.ui.view">
        <field name="name">quotation.revision.request.form</field>
        <field name="model">quotation.revision.request</field>
        <field name="arch" type="xml">
            <form string="Revision Request">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,approved,more_changes,escalated"/>

                    <!-- Pending Actions (for SE) -->
                    <button name="action_submit_revision_request" type="object"
                            string="📤 Submit to VH" class="btn-primary"
                            invisible="status != 'pending'"
                            data-hotkey="v"/>

                    <!-- VH Actions -->
                    <button name="action_approve_revision" type="object"
                            string="✅ Approve Revision" class="btn-success"
                            invisible="status != 'pending'"
                            data-hotkey="a"/>

                    <button name="action_request_more_changes" type="object"
                            string="📝 Request More Changes" class="btn-warning"
                            invisible="status != 'pending'"
                            data-hotkey="m"/>

                    <button name="action_escalate" type="object"
                            string="⚠️ Escalate" class="btn-danger"
                            invisible="status != 'pending'"
                            data-hotkey="e"/>
                </header>
                <sheet>
                    <group>
                        <group string="Reference">
                            <field name="name" readonly="1"/>
                            <field name="quotation_id" readonly="1"/>
                            <field name="lead_id" readonly="1"/>
                        </group>
                        <group string="Status">
                            <field name="status" readonly="1"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="review_date" readonly="1"/>
                            <field name="reviewed_by" readonly="1"/>
                        </group>
                    </group>

                    <!-- Client's Change Request -->
                    <group string="Client's Request" invisible="status != 'pending'">
                        <field name="client_request" nolabel="1"
                               placeholder="What does the client want changed?"/>
                    </group>
                    <group string="Client's Request (View Only)" invisible="status == 'pending'">
                        <field name="client_request" readonly="1" nolabel="1"/>
                    </group>

                    <!-- VH Notes -->
                    <group string="VH Notes" invisible="status == 'pending'">
                        <field name="vh_notes" nolabel="1"
                               placeholder="Enter notes about the revision..."/>
                    </group>

                    <!-- Escalation -->
                    <group string="Escalation" invisible="status != 'escalated'">
                        <field name="escalation_level" readonly="1"/>
                        <field name="escalation_notes" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- QUOTATION REVISION REQUEST — Tree View                               -->
    <!-- ================================================================== -->
    <record id="quotation_revision_request_view_tree" model="ir.ui.view">
        <field name="name">quotation.revision.request.tree</field>
        <field name="model">quotation.revision.request</field>
        <field name="arch" type="xml">
            <list string="Revision Requests">
                <field name="name"/>
                <field name="quotation_name"/>
                <field name="lead_name"/>
                <field name="client_request" string="Client Request"/>
                <field name="status" widget="badge"
                        decoration-success="status == 'approved'"
                        decoration-warning="status in ('pending', 'escalated')"
                        decoration-danger="status == 'more_changes'"/>
                <field name="requested_by"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- QUOTATION REVISION REQUEST — Search View                             -->
    <!-- ================================================================== -->
    <record id="quotation_revision_request_view_search" model="ir.ui.view">
        <field name="name">quotation.revision.request.search</field>
        <field name="model">quotation.revision.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="quotation_id"/>
                <field name="lead_id"/>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- QUOTATION REVISION REQUEST — Action                                  -->
    <!-- ================================================================== -->
    <record id="action_quotation_revision_request" model="ir.actions.act_window">
        <field name="name">Revision Requests</field>
        <field name="res_model">quotation.revision.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_status': 1}</field>
    </record>

    <!-- Link tree view to action -->
    <record id="act_revision_request_view_tree" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="action_quotation_revision_request"/>
        <field name="view_id" ref="quotation_revision_request_view_tree"/>
    </record>

    <!-- Link form view to action -->
    <record id="act_revision_request_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="act_window_id" ref="action_quotation_revision_request"/>
        <field name="view_id" ref="quotation_revision_request_view_form"/>
    </record>

</odoo>