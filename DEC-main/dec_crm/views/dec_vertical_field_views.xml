<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- VERTICAL FIELD GROUP — Form View (opened from vertical's tab)       -->
    <!-- ================================================================== -->
    <record id="dec_vertical_field_group_view_form" model="ir.ui.view">
        <field name="name">dec.vertical.field.group.form</field>
        <field name="model">dec.vertical.field.group</field>
        <field name="arch" type="xml">
            <form string="Field Group">
                <sheet>
                    <group string="Group Details">
                        <field name="name" placeholder="e.g. 1. Project &amp; Location"/>
                        <field name="sequence"/>
                        <field name="vertical_id" readonly="1"/>
                    </group>
                    <separator string="Fields in this Group"/>
                    <field name="field_definition_ids">
                        <list string="Fields" editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"
                                   placeholder="e.g. Fire Resistance Rating (FRR)"
                                   string="Field Label"/>
                            <field name="field_type" string="Type"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VERTICAL FIELD GROUP — List View (inline in vertical form tab)      -->
    <!-- ================================================================== -->
    <record id="dec_vertical_field_group_view_tree" model="ir.ui.view">
        <field name="name">dec.vertical.field.group.list</field>
        <field name="model">dec.vertical.field.group</field>
        <field name="arch" type="xml">
            <list string="Field Groups" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"
                       placeholder="e.g. 1. Project &amp; Location"
                       string="Group Name"/>
                <field name="field_definition_ids" widget="many2many_tags"
                       readonly="1"
                       string="Fields"
                       options="{'color_field': 'field_type'}"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VERTICAL FIELD DEFINITION — Form View (used inside group form)      -->
    <!-- ================================================================== -->
    <record id="dec_vertical_field_definition_view_form" model="ir.ui.view">
        <field name="name">dec.vertical.field.definition.form</field>
        <field name="model">dec.vertical.field.definition</field>
        <field name="arch" type="xml">
            <form string="Field Definition">
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. Door Location"/>
                        <field name="field_type"/>
                        <field name="sequence"/>
                        <field name="group_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
